# ---- Homebrew bootstrap (arch-aware: Intel /usr/local, Apple Silicon /opt/homebrew) ----
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Quiet & fast brew: skip auto-update before every install, skip post-install
# cleanup chatter, drop env hints and analytics nags. Run `brew update`
# manually when you actually want fresh formulae.
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_NO_INSTALL_CLEANUP=1
export HOMEBREW_NO_ENV_HINTS=1
export HOMEBREW_NO_ANALYTICS=1

# ---- Toolchains & PATH ----
export EDITOR='nvim'
export GOPATH="$HOME/go"
export GOTOOLCHAIN=auto
export PATH="$HOME/.local/bin:$HOME/go/bin:$HOME/src/git/scripts:$PATH"
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$HOME/.cargo/bin:$PATH"
[[ -d "/Library/TeX/texbin" ]] && export PATH="$PATH:/Library/TeX/texbin"

# ---- mise (per-repo tool versions; auto-activates on cd) ----
command -v mise >/dev/null && eval "$(mise activate zsh)"

# ---- SSH agent: auto-load passphraseless default keys ----
# `ssh-add -l` is a fast no-op when keys are already loaded (exit 0).
# Exit 1 = agent running but empty -> we load. Exit 2 = no agent -> skip.
# Loads whichever standard key files exist (RSA on personal, ECDSA on work).
if ! ssh-add -l >/dev/null 2>&1; then
  for _key in ~/.ssh/id_ed25519 ~/.ssh/id_ecdsa ~/.ssh/id_rsa; do
    [[ -f $_key ]] && ssh-add -q "$_key" 2>/dev/null
  done
  unset _key
fi
