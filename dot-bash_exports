# ---- Homebrew bootstrap (arch-aware: Intel /usr/local, Apple Silicon /opt/homebrew) ----
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Quiet & fast brew: skip auto-update before every install, skip post-install
# cleanup chatter, drop env hints and analytics nags. Run `brew update`
# manually when you actually want fresh formulae.
export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_NO_INSTALL_CLEANUP=1
export HOMEBREW_NO_ENV_HINTS=1
export HOMEBREW_NO_ANALYTICS=1

# ---- Toolchains & PATH ----
export EDITOR='nvim'
export GOPATH="$HOME/go"
export GOTOOLCHAIN=auto
export PATH="$HOME/.local/bin:$HOME/go/bin:$HOME/src/git/scripts:$PATH"
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$HOME/.cargo/bin:$PATH"
[[ -d "/Library/TeX/texbin" ]] && export PATH="$PATH:/Library/TeX/texbin"

# ---- mise (per-repo tool versions; auto-activates on cd) ----
command -v mise >/dev/null && eval "$(mise activate zsh)"
