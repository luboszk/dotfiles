# ============================================================================
# Architecture notes — read before editing
# ============================================================================
#
# Plugin manager: zinit, in *turbo mode* (line ~52 below). Plugins and compinit
# load AFTER the prompt appears, so the shell feels instant.
#
# Implication: at the time this file is being parsed, `compdef` and `complete`
# DO NOT EXIST. Any line that calls them at parse time will fail with:
#     zsh: command not found: compdef
#
# How to register a completion safely:
#   1. Define the completion function at top level (a plain shell function —
#      no compinit required).
#   2. Add `compdef <fn> <command>` (or `complete ...`) INSIDE the
#      `_load_deferred_completions` function — zinit fires it after compinit
#      via `atinit"...; _load_deferred_completions"`.
#
# Same rule applies to tool completions that internally call compdef/complete
# (gh, kubectl, terraform are already wired up this way as examples).
#
# Other load-bearing pieces:
#   - History: shared across sessions (`share_history`), dedup on save.
#   - FZF: `fzf --zsh` provides keybindings; fd is the underlying lister;
#     previews use bat/eza.
#   - Profile split: ~/.zshenv sets DOTFILES_PROFILE (work|personal). This
#     file then sources ~/.zshrc.$PROFILE and ~/.zshrc.$PROFILE.local (the
#     `.local` files are gitignored for secrets / per-machine config).
#   - Secrets: 1Password on work, macOS Keychain on personal, ~/.secrets.local
#     for one-offs.
# ============================================================================

# Load aliases and exports
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

if [ -f ~/.bash_exports ]; then
    . ~/.bash_exports
fi

alias reload-zsh="source ~/.zshrc"
alias edit-zsh="nvim ~/.zshrc"

# history setup
HISTFILE=$HOME/.zhistory
SAVEHIST=1000
HISTSIZE=999
setopt share_history 
setopt hist_expire_dups_first
setopt hist_ignore_dups
setopt hist_verify

# completion using arrow keys (based on history)
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# enable vi keybinding mode
bindkey -v

# ---- zinit (zsh plugin manager) ----
source "$(brew --prefix)/opt/zinit/zinit.zsh"

# Deferred until after compinit runs (turbo mode): tools whose completion
# scripts call compdef/complete and would otherwise error at shell start.
_load_deferred_completions() {
  # bashcompinit provides `complete` (bash-style); terraform needs it
  autoload -Uz bashcompinit && bashcompinit
  command -v gh >/dev/null && eval "$(gh completion -s zsh)"
  command -v kubectl >/dev/null && source <(kubectl completion zsh)
  command -v terraform >/dev/null && complete -o nospace -C terraform tf
  compdef _make_targets make
}

# Make: complete only targets (built-in _make also offers every env var as VAR=)
_make_targets() {
  local targets
  targets=(${(f)"$(make -pRrq 2>/dev/null | awk -F: '/^[a-zA-Z0-9][^$#\/\t=]*:([^=]|$)/ {print $1}' | sort -u)"})
  compadd -a targets
}

# Turbo mode: plugins load after prompt for snappy shell startup
zinit wait lucid for \
    atinit"ZINIT[COMPINIT_OPTS]=-C; zicompinit; zicdreplay; _load_deferred_completions" \
        zdharma-continuum/fast-syntax-highlighting \
    atload"_zsh_autosuggest_start" \
        zsh-users/zsh-autosuggestions \
    blockf atpull'zinit creinstall -q .' \
        zsh-users/zsh-completions

# ---- FZF -----

# Set up fzf key bindings and fuzzy completion
eval "$(fzf --zsh)"

# --- setup fzf theme ---
fg="#CBE0F0"
bg="#011628"
bg_highlight="#143652"
purple="#B388FF"
blue="#06BCE4"
cyan="#2CF9ED"

export FZF_DEFAULT_OPTS=" \
  --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
  --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
  --color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
  --color=selected-bg:#45475a \
  --multi"

# -- Use fd instead of fzf --

export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

# Use fd (https://github.com/sharkdp/fd) for listing path candidates.
# - The first argument to the function ($1) is the base path to start traversal
# - See the source code (completion.{bash,zsh}) for the details.
_fzf_compgen_path() {
  fd --hidden --exclude .git . "$1"
}

# Use fd to generate the list for directory completion
_fzf_compgen_dir() {
  fd --type=d --hidden --exclude .git . "$1"
}

source ~/fzf-git.sh/fzf-git.sh

show_file_or_dir_preview="if [ -d {} ]; then eza --tree --color=always {} | head -200; else bat -n --color=always --line-range :500 {}; fi"

export FZF_CTRL_T_OPTS="--preview '$show_file_or_dir_preview'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"

# Advanced customization of fzf options via _fzf_comprun function
# - The first argument to the function is the name of the command.
# - You should make sure to pass the rest of the arguments to fzf.
_fzf_comprun() {
  local command=$1
  shift

  case "$command" in
    cd)           fzf --preview 'eza --tree --color=always {} | head -200' "$@" ;;
    export|unset) fzf --preview "eval 'echo \${}'"         "$@" ;;
    ssh)          fzf --preview 'dig {}'                   "$@" ;;
    *)            fzf --preview "$show_file_or_dir_preview" "$@" ;;
  esac
}

# ----- Bat (better cat) -----

export BAT_THEME="Catppuccin Mocha"
alias cat="bat"

# ---- Eza (better ls) -----

alias ls="eza --icons=always"

# ---- Zoxide (better cd) ----
eval "$(zoxide init zsh)"

# ---- Colima (container runtime) ----
alias docker-start='colima start'
alias docker-stop='colima stop'
alias docker-status='colima status'


command -v direnv >/dev/null && eval "$(direnv hook zsh)"

# Aliases are safe to set synchronously; the matching completion scripts
# (gh, kubectl, terraform) are loaded by _load_deferred_completions above.
if command -v kubectl >/dev/null; then
  alias kctx=kubectx
  alias kns=kubens
  alias kgp='kubectl get pods'
  alias kgs='kubectl get svc'
  alias kdp='kubectl describe pod'
  alias kl='kubectl logs -f'
fi

command -v terraform >/dev/null && alias tf=terraform

command -v assume >/dev/null && alias awsume='source assume'
alias aws-populate='granted sso populate'

# ---- Secrets (env- and machine-aware) ----
# work    → 1Password CLI (set DOTFILES_PROFILE=work in ~/.zshenv on work machine)
# personal → macOS Keychain
# one-offs → ~/.secrets.local (gitignored)
if [[ "$DOTFILES_PROFILE" == "work" ]] && command -v op >/dev/null; then
  # Empty for now
else
  # Same here
fi
[[ -f ~/.secrets.local ]] && source ~/.secrets.local

# ---- Profile-specific config ----
# Set DOTFILES_PROFILE=work in ~/.zshenv on the work machine.
# Tracked: dot-zshrc.work / dot-zshrc.personal (shared, non-sensitive)
# Untracked: ~/.zshrc.work.local / ~/.zshrc.personal.local (secrets, internal URLs, etc.)
[[ -n "$DOTFILES_PROFILE" ]] && source ~/.zshrc.$DOTFILES_PROFILE 2>/dev/null
[[ -n "$DOTFILES_PROFILE" ]] && source ~/.zshrc.$DOTFILES_PROFILE.local 2>/dev/null

# ---- Starship ----
eval "$(starship init zsh)"

