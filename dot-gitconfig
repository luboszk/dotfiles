[user]
	name = Lubosz Kosnik
	email = lubosz.kosnik@gmail.com
[url "git@github.com:"]
	insteadOf = https://github.com/
[push]
	default = simple
[credential]
	helper = osxkeychain
[pull]
	ff = only
[init]
	defaultBranch = main
[fetch]
	prune = true
[rerere]
	enabled = true
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
	algorithm = histogram
[core]
	pager = delta
	excludesfile = ~/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	defaultKeyCommand = ssh-add -L
[alias]
	rebaseatmain = pull --rebase origin main
	prs-merged = "!f() { git log --format=oneline ${1-main}..${2-HEAD} | grep 'Merge pull request' | awk '{ print substr($5, 2) }' | xargs -I {} gh pr view {} --json number,title,author,url -t 'PR {{.number}}: {{.title}} by {{.author.login}} ({{.url}})'; }; f"
	parent = "!git show-branch | grep '*' | grep -v \"$(git rev-parse --abbrev-ref HEAD)\" | head -n1 | sed 's/.*\\[\\(.*\\)\\].*/\\1/' | sed 's/[\\^~].*//' #"
	bclean = "!f() { git branch --merged ${1-main} | grep -v \" ${1-main}$\" | xargs git branch -d; }; f"

# Per-machine identity: inside ~/work/ the work email is layered in.
# Create ~/.gitconfig-work manually on the work machine — it is never committed.
[includeIf "gitdir:~/work/"]
	path = ~/.gitconfig-work
