[user]
	name = Lubosz Kosnik
	email = 6192897+luboszk@users.noreply.github.com
[url "git@github.com:"]
	insteadOf = https://github.com/
[push]
	default = simple
[credential]
	helper = osxkeychain
[pull]
	ff = only
[init]
	defaultBranch = main
[fetch]
	prune = true
[rerere]
	enabled = true
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
	algorithm = histogram
[core]
	pager = delta
	excludesfile = ~/.gitignore_global
[interactive]
	diffFilter = delta --color-only
[include]
	path = ~/.config/git/catppuccin.gitconfig
[delta]
	features = catppuccin-mocha
	navigate = true
	side-by-side = true
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	defaultKeyCommand = ssh-add -L
[alias]
	default-branch = "!git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||' || git branch --list main master | grep -m1 . | tr -d '* '"
	rebaseatmain = "!git pull --rebase origin $(git default-branch)"
	prs-merged = "!f() { b=$(git default-branch); git log --format=oneline ${1-$b}..${2-HEAD} | grep 'Merge pull request' | awk '{ print substr($5, 2) }' | xargs -I {} gh pr view {} --json number,title,author,url -t 'PR {{.number}}: {{.title}} by {{.author.login}} ({{.url}})'; }; f"
	parent = "!git show-branch | grep '*' | grep -v \"$(git rev-parse --abbrev-ref HEAD)\" | head -n1 | sed 's/.*\\[\\(.*\\)\\].*/\\1/' | sed 's/[\\^~].*//' #"
	bclean = "!f() { b=$(git default-branch); git branch --merged ${1-$b} | grep -v \" ${1-$b}$\" | xargs git branch -d; }; f"

# Per-directory identity overrides. The top-level email above is a GitHub
# noreply so the real address never leaks by default. These includes layer
# in real emails only where attribution is wanted. Both .gitconfig-* files
# are untracked and generated by scripts/bootstrap.sh on first run.
[includeIf "gitdir:~/work/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/personal/"]
	path = ~/.gitconfig-personal
